APP_ENV=local
LOG_LEVEL=INFO
TIMEZONE=Europe/Moscow

JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
PREDICTION_COST_CREDITS=1
CREDIT_PRICE_RUB=1
STANDARD_SUBSCRIPTION_PRICE_RUB=399
PRO_SUBSCRIPTION_PRICE_RUB=999
ADMIN_EMAIL=admin@example.test
ADMIN_PASSWORD=admin

TELEGRAM_BOT_TOKEN=
# Прокси для запросов к Telegram API. В РФ может быть нужен для обхода блокировок.
TELEGRAM_PROXY_URL=

HH_ACCESS_TOKEN=
HH_USER_AGENT=coverai/0.1.0
# Прокси для запросов к hh.ru. В РФ может быть нужен для обхода блокировок.
HH_PROXY_URL=
HH_HTML_FALLBACK_ENABLED=true

LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-chat-v3.2
# Прокси для запросов к LLM API. В РФ может быть нужен для обхода блокировок.
LLM_PROXY_URL=

POSTGRES_DB=coverai
POSTGRES_USER=coverai
POSTGRES_PASSWORD=coverai
DATABASE_URL=postgresql+asyncpg://coverai:coverai@postgres:5432/coverai

REDIS_URL=redis://redis:6379/0

METRICS_ENABLED=true
BOT_METRICS_PORT=8002
WORKER_METRICS_PORT=8001
